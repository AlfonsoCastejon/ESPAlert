# Base de datos
POSTGRES_DB=espalert
POSTGRES_USER=espalert
POSTGRES_PASSWORD=cambia_esto

# FastAPI — DATABASE_URL la construye el compose a partir de las variables de POSTGRES_*
# En Railway, esta variable la inyecta automáticamente el plugin de PostgreSQL
REDIS_URL=redis://redis:6379/0
# En Railway, esta variable la inyecta automáticamente el plugin de Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000

# Web Push VAPID — genera las claves con: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=tu@email.com

# AEMET — obtén la clave en https://opendata.aemet.es/centrodedescargas/inicio
AEMET_API_KEY=

# Autenticación JWT — genera un secreto con: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# Next.js — en producción usa tu dominio sin puerto (nginx/caddy se encarga)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
